APP_NAME="Sistema de Chamados"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# =============================================================================
# DOCKER — variáveis otimizadas para performance local
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sistema_chamados
DB_USERNAME=root_docker
DB_PASSWORD=password

# Sessão e cache em Redis (menos I/O que database/file no bind mount Windows)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Aquecimento de cache no bootstrap do container (config + routes)
DOCKER_WARM_CACHE=true

# =============================================================================
# LOCAL (Laragon) — comente o bloco DOCKER acima e descomente abaixo
# =============================================================================
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sistema_chamados
# DB_USERNAME=root
# DB_PASSWORD=
# SESSION_DRIVER=database
# CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# SMTP via Mailpit (container mailpit) — caixa de entrada: http://localhost:8025
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sistema-chamados.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_URL=http://localhost:8025

VITE_APP_NAME="${APP_NAME}"
