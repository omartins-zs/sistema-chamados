APP_NAME="Sistema de Chamados"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
# Local (Laragon / MySQL na máquina):
#   DB_HOST=127.0.0.1  DB_PORT=3306
# Docker Compose (automático — docker-compose.yml sobrescreve DB_* e REDIS_*):
#   DB_HOST=mysql     DB_PORT=3306  DB_USERNAME=chamados  DB_PASSWORD=chamados
# SQLite (rápido, sem MySQL):
#   DB_CONNECTION=sqlite  DB_DATABASE=database/database.sqlite

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistema_chamados
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# E-mail
# -----------------------------------------------------------------------------
# Local: grava em storage/logs/laravel.log
MAIL_MAILER=log

# SMTP (Mailpit local :1025 ou container mailpit no Docker)
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAILPIT_UI_URL=http://127.0.0.1:8025

MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sistema-chamados.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
