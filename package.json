{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test:frontend": "vitest run",
        "test:frontend:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:public": "playwright test --project=public",
        "test:e2e:admin": "playwright test --project=admin",
        "test:e2e:ui": "playwright test --ui",
        "test:browser": "npm run test:e2e",
        "test:js": "npm run test:frontend",
        "test:js:all": "npm run test:frontend && npm run test:e2e"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@tailwindcss/vite": "^4.3.0",
        "@vitest/coverage-v8": "^3.2.4",
        "concurrently": "^9.0.1",
        "jsdom": "^26.1.0",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^5.8.3",
        "vite": "^8.0.0",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "flowbite": "^4.0.2",
        "flowbite-datepicker": "^2.0.0"
    }
}
